# Base de données
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hubevent"

# JWT
JWT_SECRET="change-me-to-a-random-secret"

# Serveur
PORT=4000
NODE_ENV=development

# FedaPay
FEDAPAY_API_KEY="sk_sandbox_xxx"
FEDAPAY_SECRET_KEY="sk_sandbox_xxx"
FEDAPAY_MODE="sandbox"

# Twilio SMS
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# OTP
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN=60
